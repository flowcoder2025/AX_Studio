# AX Studio — Environment Variables
# Copy this file to .env.local and fill in your values

# === Claude CLI ===
# Claude Code CLI path (default: 'claude' from system PATH)
# Max 구독 필요 — CLI를 child_process.spawn으로 호출
# CLAUDE_CLI_PATH=claude

# === ComfyUI ===
COMFYUI_URL=http://127.0.0.1:8000
COMFYUI_WS=ws://127.0.0.1:8000/ws

# === Kling API (optional) ===
KLING_API_KEY=your_kling_api_key_here
KLING_API_URL=https://api.kling.ai/v1

# === FFmpeg ===
# Windows: download from https://ffmpeg.org/download.html
# Set path if not in system PATH
FFMPEG_PATH=ffmpeg

# === Output ===
OUTPUT_DIR=./output

# === Database ===
# SQLite (better-sqlite3) — data/ax-studio.db에 자동 생성
# DATABASE_URL=file:./data/ax-studio.db
