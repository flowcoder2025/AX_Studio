{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "comfyui": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "comfyui-mcp@latest"
      ],
      "env": {
        "COMFYUI_URL": "http://127.0.0.1:8000"
      }
    }
  }
}
