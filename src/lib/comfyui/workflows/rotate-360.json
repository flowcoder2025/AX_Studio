{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "product_cutout.png"
    }
  },
  "2": {
    "class_type": "ImageResizeKJ",
    "inputs": {
      "image": ["1", 0],
      "width": 576,
      "height": 576,
      "upscale_method": "lanczos",
      "keep_proportion": true,
      "divisible_by": 1
    }
  },
  "3": {
    "class_type": "ImageOnlyCheckpointLoader",
    "inputs": {
      "ckpt_name": "sv3d_p.safetensors"
    }
  },
  "5": {
    "class_type": "SV3D_Conditioning",
    "inputs": {
      "clip_vision": ["3", 1],
      "init_image": ["2", 0],
      "vae": ["3", 2],
      "width": 576,
      "height": 576,
      "video_frames": 21,
      "elevation": 10.0
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["3", 0],
      "positive": ["5", 0],
      "negative": ["5", 1],
      "latent_image": ["5", 2],
      "seed": 0,
      "steps": 25,
      "cfg": 3.0,
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["3", 2]
    }
  },
  "20": {
    "class_type": "RIFE VFI",
    "inputs": {
      "ckpt_name": "rife49.pth",
      "frames": ["7", 0],
      "clear_cache_after_n_frames": 10,
      "multiplier": 4,
      "fast_mode": true,
      "ensemble": true,
      "scale_factor": 1.0,
      "dtype": "float16",
      "torch_compile": false,
      "batch_size": 1
    }
  },
  "30": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["20", 0],
      "filename_prefix": "rotate360_frames"
    }
  },
  "_meta": {
    "name": "360° Product Rotation (SV3D)",
    "ax_studio": {
      "workflow_id": "rotate-360",
      "input_nodes": {
        "image": "1",
        "elevation": "5",
        "seed": "6"
      },
      "output_nodes": {
        "frames": "30"
      },
      "notes": "sv3d_p.safetensors 사용. 21프레임 생성 → RIFE 4x 보간 → 84프레임 → FFmpeg MP4."
    }
  }
}
